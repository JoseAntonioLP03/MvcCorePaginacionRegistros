@model List<Empleado>


<h1  style="color:lawngreen;background-color:seagreen">Paginación en grupo EMPLEADOS</h1>

<hr />
@{
    int numeroRegistros = (int)ViewData["NUMEROREGISTROS"];
    int numPagina = 1;
}
@for (int i = 1; i <= numeroRegistros; i += 3)
{
    <a asp-controler="Paginacion" asp-action="GrupoEmpleados" asp-route-posicion="@i"> @numPagina</a>
    numPagina = numPagina + 1;
}
<hr />

<table class="table table-warning">
    <thead>
        <tr>
            <th>EMP_NO</th>
            <th>APELLIDO</th>
            <th>OFICIO</th>
            <th>SALARIO</th>
            <th>DEPT_NO</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Empleado emp in Model)
        {
            <tr>
                <td>@emp.IdEmpleado</td>
                <td>@emp.Apellido</td>
                <td>@emp.Oficio</td>
                <td>@emp.Salario</td>
                <td>@emp.IdDepartamento</td>
            </tr>
        }
    </tbody>
</table>